# manifest.yaml
# Generated by Exastro CDK init
workspace_id: "{{ workspace_id }}"

conductor:
  name: "{{ conductor_name | default('New Conductor') }}"
  description: "{{ conductor_description | default('Created by Exastro CDK') }}"

# List of ITA resources to be provisioned
# 開発者が「やりたい作業」のリスト
movements:
{%- if movements %}
  {%- for movement in movements %}
  - name: "{{ movement.name }}"
    description: "{{ movement.description }}"
    orchestrator: "ansible_role"       # ansible_role のみサポート (ansible_legacy は TODO)
    host_specific_format: "IP"         # "IP" のみサポート (ホスト名は TODO)
  {%- endfor %}
{%- else %}
  # デフォルトのサンプルMovement
  - name: "sample_movement"
    description: "サンプルムーブメント（ここを編集してください）"
    orchestrator: "ansible_role"
    host_specific_format: "IP"
{%- endif %}
