{
    "python.defaultInterpreterPath": "${workspaceFolder}/exastro-cdk/venv/bin/python",
    "mypy-type-checker.args": [
        "\"mypy-type-checker.args\" = [\"--config-file=exastro-cdk/pyproject.toml\"]"
    ],
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/venv": true,
        "**/.pytest_cache": true,
        "**/.mypy_cache": true,
    },
    "workbench.colorCustomizations": {
        "titleBar.activeBackground": "#1a203d",
        "titleBar.activeForeground": "#bdc1ff",
        "titleBar.inactiveBackground": "#122b1a",
        "titleBar.inactiveForeground": "#5a5e9e",
        "activityBar.background": "#122b1a",
        "activityBar.foreground": "#bdc1ff",
        "activityBar.inactiveForeground": "#bdc1ff",
        "activityBarBadge.background": "#bdc1ff",
        "activityBarBadge.foreground": "#0d1f14",
        "sideBar.background": "#0f2418",
        "sideBar.foreground": "#dcdeff",
        "sideBarTitle.foreground": "#bdc1ff",
        "sideBarSectionHeader.background": "#122b1a",
        "sideBarSectionHeader.foreground": "#bdc1ff",
        "editor.background": "#0d1f14",
        "editor.foreground": "#bdc1ff",
        "editor.lineHighlightBackground": "#1a3d28",
        "editorLineNumber.foreground": "#2d4e6a",
        "editorLineNumber.activeForeground": "#6d7fbf",
        "editorCursor.foreground": "#5a5e9e",
        "editor.selectionBackground": "#1a4d2880",
        "statusBar.background": "#1a4d28",
        "statusBar.foreground": "#bdc1ff",
        "statusBar.noFolderBackground": "#0d1f14",
        "statusBarItem.hoverBackground": "#2d4e6a",
        "tab.activeBackground": "#384761",
        "tab.activeForeground": "#bdc1ff",
        "tab.inactiveBackground": "#0f2418",
        "tab.inactiveForeground": "#5a5e9e",
        "tab.border": "#122b1a",
        "panel.background": "#0d1f14",
        "panel.border": "#1a3d22",
        "panelTitle.activeForeground": "#bdc1ff",
        "panelTitle.inactiveForeground": "#5872bb",
        "terminal.background": "#0d1f14",
        "terminal.foreground": "#bdc1ff",
        "terminal.ansiGreen": "#5a5e9e",
        "terminal.ansiBrightGreen": "#bdc1ff"
    },
    "ruff.exclude": [
        "tests"
    ]
}